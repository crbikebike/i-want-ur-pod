# --- Fixture data: default-deny -------------------------------------------
# Your real subscription export (may contain PRIVATE member-feed tokens and
# personalized titles) must never be committed. Everything in fixtures/ is
# ignored EXCEPT the sanitized, public sample.
fixtures/*.json
fixtures/*.opml
!fixtures/sample-podcasts.json

# --- Xcode / Swift Package Manager ----------------------------------------
# The .xcodeproj is generated by XcodeGen, never hand-committed.
*.xcodeproj/
.build/
DerivedData/
xcuserdata/
*.xcuserstate
.swiftpm/
Packages/*/.build/

