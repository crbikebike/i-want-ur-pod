<?xml version="1.0" encoding="UTF-8"?>
<!--
  Info.plist for the IWantUrPod app target.
  Architecture source: ROADMAP.md §M1 (SwiftUI lifecycle app + a dormant CarPlay
  seam that goes live at M3). The CarPlay scene configuration below is PRESENT
  but INERT for M1: CarPlaySceneDelegate is a skeleton and the carplay-audio
  entitlement (IWantUrPod.entitlements) requires Apple approval before it does
  anything on real hardware. Do not remove — later milestones fill in the seam.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>i want ur pod</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Non-exempt encryption: app uses only standard HTTPS, so declare exempt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Keeps audio playing (and enables the lock-screen Now Playing UI) when the app is backgrounded or the screen locks. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>

	<!-- Launch screen: plain themed ground; the real chrome mounts instantly. -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>

	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<key>UIApplicationSceneManifest</key>
	<dict>
		<!-- Multiple scenes: the phone/pad window plus a CarPlay scene role. -->
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
		<key>UISceneConfigurations</key>
		<dict>
			<!-- Standard SwiftUI window scene (the app UI). -->
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>Default Configuration</string>
				</dict>
			</array>

			<!--
			  CarPlay audio-app scene role. Present as the M1 seam and wired to
			  a skeleton CarPlaySceneDelegate; the templates it hosts only come
			  alive at M3, gated on Apple approving com.apple.developer.carplay-audio.
			-->
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneConfigurationName</key>
					<string>CarPlay Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
</dict>
</plist>
